rules_version = '2';

// قواعد أمان Firestore لتطبيق Order
// للتفعيل: Firebase Console → Firestore Database → Rules، الصق هذا الملف كاملاً
// ثم اضغط "نشر/Publish". بدون نشر هذه القواعد فعلياً في الكونسول، قاعدة البيانات
// تبقى بوضعها الافتراضي (غالباً مرفوضة للجميع أو مفتوحة تماماً بحسب اختيارك عند
// إنشاء قاعدة البيانات لأول مرة) — الكود في order.html لا يكفي بمفرده لتفعيلها.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ── ملفات المستخدمين (عملاء وسائقون) ──
    // القراءة مفتوحة لأي مستخدم مسجَّل دخول: العميل يحتاج قراءة ملف السائق المُسنَد
    // له (الاسم، الهاتف، التقييم، الموقع الحي)، وكل عميل يحتاج رؤية السائقين
    // المتصلين القريبين قبل الطلب. لا كلمات مرور أو بيانات حسّاسة مخزَّنة هنا أصلاً
    // (تلك عند Firebase Auth نفسه) فهذا الانفتاح مقبول لحجم تطبيق كهذا.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ── الطلبات ──
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        (resource.data.status == 'pending' && resource.data.driverId == null)
      );
      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.driverId == null;
      allow update: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        (resource.data.status == 'pending' && resource.data.driverId == null && request.resource.data.driverId == request.auth.uid)
      );
      allow delete: if false;
    }

    // ── الإشعارات — كل مستخدم يقرأ إشعاراته الخاصة فقط عبر recipientId ──
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if false;
    }
  }
}
